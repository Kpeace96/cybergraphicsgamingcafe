  <script>
    // --- Order Form -> WhatsApp ---
    const form = document.getElementById('orderForm');
    const waNumber = '27814333648';

    form.addEventListener('submit', e => {
      e.preventDefault();
      const fd = new FormData(form);
      const promo = fd.get('promo') ? `%0APromo code: ${fd.get('promo')}` : '';
      const msg = `Hi, I would like to order:%0AName: ${fd.get('name')}%0AEmail: ${fd.get('email')}%0AService: ${fd.get('service')}%0ABudget/Time: ${fd.get('budget') || '-'}${promo}%0ADetails: ${fd.get('details')}`;
      const url = `https://wa.me/${waNumber}?text=${msg}`;
      window.open(url, '_blank', 'noopener');
    });

    // --- Live Comment Section ---
    const commentForm = document.getElementById('commentForm');
    const commentsList = document.getElementById('commentsList');
    const STORAGE_KEY = 'cgc_comments';

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function loadComments() {
      const comments = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      commentsList.innerHTML = '';
      if (comments.length === 0) {
        commentsList.innerHTML = '<p class="muted" style="text-align:center;">No comments yet. Be the first to share your thoughts!</p>';
        return;
      }
      comments.forEach(c => {
        const div = document.createElement('div');
        div.className = 'comment-card';
        div.innerHTML = `
          <p style="margin:0 0 6px;">"${escapeHtml(c.text)}"</p>
          <strong>— ${escapeHtml(c.name)}</strong>
          <div class="comment-meta">${escapeHtml(c.date)}</div>
        `;
        commentsList.appendChild(div);
      });
    }

    commentForm.addEventListener('submit', e => {
      e.preventDefault();
      const name = document.getElementById('commentName').value.trim();
      const text = document.getElementById('commentText').value.trim();
      if (!name || !text) return;

      const comments = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      comments.unshift({
        name,
        text,
        date: new Date().toLocaleString('en-ZA', { dateStyle: 'medium', timeStyle: 'short' })
      });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(comments));
      commentForm.reset();
      loadComments();
    });

    loadComments();
  </script>
