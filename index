<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Cyber Graphics Gaming Cafe</title>
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <meta name="description" content="Cyber Graphics Gaming Cafe — website creation, digital graphic design, and business registration support in South Africa. Order online, get delivery via WhatsApp." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:ital,opsz,wght@1,9..144,500;1,9..144,600&family=Space+Mono:wght@400;700&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#0b1220;
      --card:#101a31;
      --card2:#0f172a;
      --text:#e5eefc;
      --muted:#a9b7d0;
      --brand:#7c5cff;
      --brand2:#25c2a0;
      --line:rgba(255,255,255,.10);
      --shadow:0 18px 60px rgba(0,0,0,.30);
      --radius:22px;
      --logo-w:64px;
      --logo-h:64px;
      --off:#6b7280;
      --off2:#94a3b8;
      --gold:#f5b942;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Inter,system-ui,sans-serif;
      background:
        radial-gradient(circle at top left, rgba(124,92,255,.20), transparent 26%),
        radial-gradient(circle at top right, rgba(37,194,160,.16), transparent 22%),
        linear-gradient(180deg, #060913 0%, #0b1220 100%);
      color:var(--text);
      overflow-x:hidden;
    }
    a{color:inherit;text-decoration:none}
    .wrap{width:min(1160px, calc(100% - 32px)); margin:0 auto}
    .promo-strip{
      background:linear-gradient(90deg, #7c5cff, #25c2a0);
      color:#08101f;
      font-weight:700;
      font-size:14px;
      text-align:center;
      padding:10px 14px;
      letter-spacing:.01em;
    }
    .promo-strip strong{font-weight:800}
    .promo-strip a{
      text-decoration:underline;
      text-underline-offset:3px;
      margin-left:6px;
    }
    .nav{
      position:sticky;
      top:0;
      z-index:20;
      backdrop-filter:blur(14px);
      background:rgba(6,9,19,.55);
      border-bottom:1px solid var(--line);
    }
    .nav-inner{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:18px 0;
      gap:14px;
      flex-wrap:wrap;
    }
    .logo{
      display:flex;
      align-items:center;
      gap:12px;
      font-weight:800;
      letter-spacing:.2px;
    }
    .logo-img{
      width:var(--logo-w);
      height:var(--logo-h);
      object-fit:cover;
      border-radius:16px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      box-shadow:0 10px 24px rgba(0,0,0,.25);
    }
    .logo-fallback{
      width:var(--logo-w);
      height:var(--logo-h);
      border-radius:16px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg,var(--brand),var(--brand2));
      font-weight:900;
      color:#fff;
      border:1px solid rgba(255,255,255,.14);
    }
    .nav-links{
      display:flex;
      gap:18px;
      flex-wrap:wrap;
      color:var(--muted);
      font-size:14px;
    }
    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      padding:14px 20px;
      border-radius:999px;
      border:1px solid transparent;
      font-weight:700;
      transition:.2s ease;
      cursor:pointer;
    }
    .btn-primary{
      background:linear-gradient(135deg,var(--brand),#9f7bff);
      color:white;
      box-shadow:0 12px 28px rgba(124,92,255,.22);
    }
    .btn-primary:hover{transform:translateY(-1px) scale(1.01)}
    .btn-ghost{
      border-color:var(--line);
      background:rgba(255,255,255,.03);
      color:var(--text);
    }
    .hero{
      padding:64px 0 34px;
      position:relative;
      overflow:hidden;
    }
    .hero::before,.hero::after{
      content:'';
      position:absolute;
      inset:auto;
      pointer-events:none;
      border-radius:50%;
      filter:blur(10px);
      opacity:.55;
      animation:floaty 8s ease-in-out infinite;
    }
    .hero::before{
      width:120px;
      height:120px;
      background:rgba(124,92,255,.22);
      top:20px;
      right:8%;
    }
    .hero::after{
      width:90px;
      height:90px;
      background:rgba(37,194,160,.20);
      bottom:10px;
      left:3%;
      animation-delay:1.5s;
    }
    .hero-grid{
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:26px;
      align-items:center;
      position:relative;
      z-index:1;
    }
    .eyebrow{
      display:inline-flex;
      gap:8px;
      align-items:center;
      color:#cfe1ff;
      background:rgba(255,255,255,.05);
      border:1px solid var(--line);
      padding:8px 14px;
      border-radius:999px;
      font-size:13px;
      margin-bottom:18px;
    }
    h1{
      font-size:clamp(40px, 6vw, 72px);
      line-height:1.02;
      margin:0 0 16px;
      letter-spacing:-.04em;
    }
    .lead{
      font-size:18px;
      line-height:1.7;
      color:var(--muted);
      max-width:54ch;
      margin:0 0 28px;
    }
    .sr-only{
      position:absolute;
      width:1px;height:1px;
      padding:0;margin:-1px;
      overflow:hidden;
      clip:rect(0,0,0,0);
      white-space:nowrap;
      border:0;
    }
    .headline-mark{
      display:block;
      width:100%;
      max-width:700px;
      height:auto;
      margin:0 0 20px;
    }
    .headline-mark .hm-cursor{
      animation: hm-blink 1.4s steps(1) infinite;
    }
    @media (prefers-reduced-motion: reduce){
      .headline-mark .hm-cursor{animation:none}
    }
    @keyframes hm-blink{
      0%,49%{opacity:1}
      50%,100%{opacity:0}
    }
    .hero-actions{display:flex;gap:12px;flex-wrap:wrap}
    .panel{
      background:rgba(16,26,49,.8);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }
    .hero-card{
      padding:24px;
      position:relative;
      overflow:hidden;
    }
    .hero-card::after{
      content:'';
      position:absolute;
      right:18px;
      top:12px;
      font-size:44px;
      opacity:.18;
      animation:bounce 2.8s ease-in-out infinite;
    }
    .stat-grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:14px;
      margin-top:16px;
    }
    .stat{
      padding:16px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
      border-radius:18px;
      transition:transform .2s ease, border-color .2s ease;
    }
    .stat:hover{
      transform:translateY(-3px);
      border-color:rgba(124,92,255,.35);
    }
    .stat b{display:block;font-size:24px;margin-bottom:6px}
    .section{padding:30px 0}
    .section h2{
      font-size:32px;
      margin:0 0 10px;
      letter-spacing:-.03em;
    }
    .section p.sub{
      margin:0 0 22px;
      color:var(--muted);
      line-height:1.7;
    }
    .cards{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
    }
    .service{
      padding:22px;
      background:linear-gradient(180deg, rgba(16,26,49,.92), rgba(15,23,42,.92));
      border:1px solid var(--line);
      border-radius:22px;
      display:flex;
      flex-direction:column;
      gap:14px;
      transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease;
      position:relative;
      overflow:hidden;
    }
    .service:hover{
      transform:translateY(-5px);
      border-color:rgba(37,194,160,.35);
      box-shadow:0 18px 40px rgba(0,0,0,.25);
    }
    .service .icon{
      width:48px;
      height:48px;
      border-radius:14px;
      display:grid;
      place-items:center;
      font-size:22px;
      background:rgba(124,92,255,.14);
      border:1px solid rgba(124,92,255,.25);
      animation:pop 2.8s ease-in-out infinite;
    }
    .price{font-size:28px;font-weight:800}
    .price .old{
      font-size:16px;
      font-weight:600;
      color:var(--muted);
      text-decoration:line-through;
      margin-right:8px;
    }
    .muted{color:var(--muted);line-height:1.65}
    .service ul{
      margin:0;
      padding-left:18px;
      color:var(--muted);
      line-height:1.7;
    }
    .service .btn{margin-top:auto}
    .service.offline{
      opacity:.78;
      background:linear-gradient(180deg, rgba(55,65,81,.90), rgba(31,41,55,.92));
      border-color:rgba(148,163,184,.22);
    }
    .service.offline .icon{
      background:rgba(148,163,184,.16);
      border-color:rgba(148,163,184,.22);
      animation:none;
    }
    .service.promo{
      border-color:rgba(245,185,66,.45);
      box-shadow:0 0 0 1px rgba(245,185,66,.18), 0 18px 40px rgba(0,0,0,.25);
    }
    .offline-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 12px;
      border-radius:999px;
      background:rgba(148,163,184,.14);
      border:1px solid rgba(148,163,184,.22);
      color:#d1d5db;
      font-size:12px;
      font-weight:700;
      letter-spacing:.02em;
      width:max-content;
    }
    .promo-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 12px;
      border-radius:999px;
      background:rgba(245,185,66,.16);
      border:1px solid rgba(245,185,66,.35);
      color:var(--gold);
      font-size:12px;
      font-weight:800;
      letter-spacing:.02em;
      width:max-content;
    }
    .btn-disabled{
      opacity:.55;
      pointer-events:none;
      filter:saturate(.75);
      cursor:not-allowed;
    }
    .how{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
    }
    .step{
      padding:22px;
      border-radius:22px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      transition:transform .2s ease;
    }
    .step:hover{transform:translateY(-4px)}
    .step-num{
      display:inline-grid;
      place-items:center;
      width:36px;
      height:36px;
      border-radius:12px;
      background:linear-gradient(135deg,var(--brand),var(--brand2));
      color:#fff;
      font-weight:800;
      margin-bottom:14px;
    }
    .testimonial{
      padding:24px;
      border-radius:22px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
    }
    .cta{
      padding:28px;
      border-radius:28px;
      background:linear-gradient(135deg, rgba(124,92,255,.18), rgba(37,194,160,.14));
      border:1px solid rgba(255,255,255,.10);
      display:flex;
      justify-content:space-between;
      gap:18px;
      align-items:center;
      flex-wrap:wrap;
    }
    .footer{
      padding:28px 0 46px;
      color:var(--muted);
      font-size:14px;
    }
    form{display:grid;gap:12px}
    input, textarea, select{
      width:100%;
      padding:14px 15px;
      border-radius:16px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      color:var(--text);
      outline:none;
      font:inherit;
    }
    textarea{
      min-height:110px;
      resize:vertical;
    }
    .grid-2{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }
    .order{
      display:grid;
      grid-template-columns:1fr .9fr;
      gap:18px;
      align-items:start;
    }
    .summary{
      padding:22px;
      border-radius:22px;
      background:rgba(255,255,255,.03);
      border:1px solid var(--line);
    }
    .summary ul{
      padding-left:18px;
      color:var(--muted);
    }
    .socials{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
    }
    .socials a{
      padding:10px 14px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.03);
      font-size:14px;
    }
    .comment-card{
      padding:20px;
      border-radius:22px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      transition:transform .2s ease;
    }
    .comment-card:hover{transform:translateY(-3px)}
    .comment-meta{
      color:var(--muted);
      font-size:12px;
      margin-top:8px;
    }
    .comment-list{
      display:grid;
      grid-template-columns:1fr;
      gap:14px;
    }
    @keyframes floaty{
      0%,100%{transform:translateY(0) rotate(0deg)}
      50%{transform:translateY(-10px) rotate(8deg)}
    }
    @keyframes bounce{
      0%,100%{transform:translateY(0)}
      50%{transform:translateY(-8px)}
    }
    @keyframes pop{
      0%,100%{transform:scale(1)}
      50%{transform:scale(1.06)}
    }
    @media (prefers-reduced-motion: reduce){
      html{scroll-behavior:auto}
      *,*::before,*::after{animation:none!important;transition:none!important}
    }
    @media (max-width: 1120px){.cards{grid-template-columns:repeat(2,1fr)}}
    @media (max-width: 980px){
      .hero-grid,.how,.order{grid-template-columns:1fr}
      .cta{flex-direction:column;align-items:flex-start}
      .cards{grid-template-columns:1fr 1fr}
      .nav-inner{justify-content:center}
    }
    @media (max-width: 640px){
      .cards,.grid-2,.stat-grid,.hero-actions{grid-template-columns:1fr}
      .cards,.how{grid-template-columns:1fr}
      .nav-links{justify-content:center}
      .wrap{width:min(1160px, calc(100% - 20px))}
    }
  </style>
</head>
